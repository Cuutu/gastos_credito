# Copiá este archivo a .env.local y completá los valores
# cp .env.example .env.local

# URL de conexión a Neon (PostgreSQL)
# La obtenés en: https://console.neon.tech → tu proyecto → Connection details
DATABASE_URL=postgresql://usuario:password@host/database?sslmode=require

# Contraseña para acceder a la app (no la subas a git)
APP_PASSWORD=tu_contraseña
